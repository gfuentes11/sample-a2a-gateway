# ============================================================================
# AgentCore A2A Sample Agents — Configuration
# ============================================================================
# Copy this file to terraform.tfvars and customize:
#   cp terraform.tfvars.example terraform.tfvars

aws_region            = "us-east-1"
stack_name            = "agentcore-a2a-sample"
environment           = "dev"
weather_agent_name    = "WeatherAgent"
calculator_agent_name = "CalculatorAgent"
network_mode          = "PUBLIC"
ecr_repository_name   = "a2a-agents"
image_tag             = "latest"

# --- VPC Mode (optional) ---
# To run agents inside a VPC, set network_mode and provide subnet/security group IDs.
# Subnets must be in supported AZs and ideally be private subnets with NAT Gateway access.
# See: https://aws.github.io/bedrock-agentcore-starter-toolkit/user-guide/security/agentcore-vpc.md
#
# network_mode       = "VPC"
# subnet_ids         = ["subnet-0123456789abcdef0", "subnet-0123456789abcdef1"]
# security_group_ids = ["sg-0123456789abcdef0"]

# Notes:
# - A Cognito User Pool is created automatically with OAuth client_credentials flow
# - Both agent runtimes are configured with customJWTAuthorizer pointing to Cognito
# - The gateway can authenticate using the client_id/client_secret from outputs
# - OAuth scopes: a2a-gateway/weather:read, weather:write, calculator:read, calculator:write, gateway:admin
# - After deploy, run `terraform output cognito_client_secret` to get the client secret
